// Prisma schema for the Notice Board
// Uses MySQL (TiDB Cloud / PlanetScale-style) by default.
// If you use Neon or Supabase (Postgres) instead, change provider below to "postgresql".

generator client {
  provider = "prisma-client-js"
}

datasource db {
  
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Category {
  Exam
  Event
  General
}

enum Priority {
  Normal
  Urgent
}

model Notice {
  id          Int      @id @default(autoincrement())
  title       String
  body        String   @db.Text
  category    Category @default(General)
  priority    Priority @default(Normal)
  publishDate DateTime
  image       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
